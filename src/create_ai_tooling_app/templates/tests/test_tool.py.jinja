from unittest.mock import MagicMock, patch

import pytest
from fastapi.testclient import TestClient

from src.{{ project_slug }}.main import app
from src.{{ project_slug }}.routes.tool import get_llm_client


@pytest.fixture
def mock_client():
    client = MagicMock()
    client.run.return_value = "mocked response"
    return client


@pytest.fixture
def test_client(mock_client):
    app.dependency_overrides[get_llm_client] = lambda: mock_client
    yield TestClient(app)
    app.dependency_overrides.clear()


def test_run_success(test_client, mock_client):
    response = test_client.post("/run", json={"input": "Hello"})
    assert response.status_code == 200
    assert response.json() == {"output": "mocked response"}
    mock_client.run.assert_called_once()


def test_run_llm_error_returns_500(test_client, mock_client):
    mock_client.run.side_effect = RuntimeError("API error")
    response = test_client.post("/run", json={"input": "Hello"})
    assert response.status_code == 500
    assert "API error" in response.json()["detail"]


def test_run_empty_input_returns_422(test_client):
    response = test_client.post("/run", json={})
    assert response.status_code == 422
